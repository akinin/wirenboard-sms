# HTTP API
API_TOKEN=<generate-with-python-command>
APP_SECRET=<generate-with-python-command>
APP_HOST=0.0.0.0
APP_PORT=8088
APP_ROLE=api
DATABASE_PATH=./data/sms_gateway.sqlite3

# Wiren Board MQTT
WB_MQTT_HOST=127.0.0.1
WB_MQTT_PORT=1883
WB_MQTT_USERNAME=
WB_MQTT_PASSWORD=
WB_SMS_TOPIC=/devices/sms_sender/controls/send/on

# SMS backend: mqtt is the default when a separate Wiren Board sends SMS.
# Use mmcli only when a modem is available inside this host/container.
SMS_BACKEND=mqtt
MMCLI_MODEM_ID=auto

# UniFi Network
UNIFI_BASE_URL=https://unifi.local
UNIFI_USERNAME=
UNIFI_PASSWORD=
UNIFI_SITE=default
UNIFI_VERIFY_TLS=false
UNIFI_AUTH_MINUTES=1440

# Hotspot admin and branding
HOTSPOT_PORTAL_PORT=8880
HOTSPOT_ADMIN_PORT=8089
HOTSPOT_PORTAL_TITLE=Welcome to Olshaniki
HOTSPOT_LOGO_PATH=./data/hotspot_logo

# Hotspot audit and Telegram notifications
HOTSPOT_ACCESS_LOG_PATH=./data/hotspot_access.csv
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# OTP policy
OTP_TTL_SECONDS=300
OTP_LENGTH=6
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5
OTP_MESSAGE_TEMPLATE=Wi-Fi code: {code}
